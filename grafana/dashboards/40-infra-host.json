{
  "uid": "oculory-infra",
  "title": "Oculory — Infra / Host (USE)",
  "tags": ["oculory", "infra", "noc"],
  "timezone": "Asia/Bangkok",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    { "type": "row", "title": "Host", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "type": "timeseries", "title": "CPU by mode", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } }, "options": { "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "sum by (mode) (rate(node_cpu_seconds_total{mode!=\"idle\"}[5m])) / scalar(count(count by (cpu)(node_cpu_seconds_total)))", "legendFormat": "{{mode}}" } ]
    },
    {
      "type": "timeseries", "title": "Memory", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [ { "refId": "A", "expr": "node_memory_MemTotal_bytes", "legendFormat": "total" }, { "refId": "B", "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "used" }, { "refId": "C", "expr": "node_memory_SwapTotal_bytes - node_memory_SwapFree_bytes", "legendFormat": "swap used" } ]
    },
    {
      "type": "timeseries", "title": "Disk space /", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [ { "refId": "A", "expr": "node_filesystem_size_bytes{mountpoint=\"/\"}", "legendFormat": "size" }, { "refId": "B", "expr": "node_filesystem_avail_bytes{mountpoint=\"/\"}", "legendFormat": "avail" } ]
    },
    {
      "type": "timeseries", "title": "Disk IO", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [ { "refId": "A", "expr": "sum(rate(node_disk_read_bytes_total[5m]))", "legendFormat": "read" }, { "refId": "B", "expr": "sum(rate(node_disk_written_bytes_total[5m]))", "legendFormat": "write" } ]
    },
    {
      "type": "timeseries", "title": "Network", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [ { "refId": "A", "expr": "sum(rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|br.*\"}[5m]))", "legendFormat": "rx" }, { "refId": "B", "expr": "sum(rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br.*\"}[5m]))", "legendFormat": "tx" } ]
    },
    { "type": "row", "title": "Containers (all)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 } },
    {
      "type": "timeseries", "title": "CPU per container", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "targets": [ { "refId": "A", "expr": "topk(15, docker_container_cpu_percent)", "legendFormat": "{{name}}" } ]
    },
    {
      "type": "timeseries", "title": "Memory per container", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [ { "refId": "A", "expr": "topk(15, docker_container_memory_usage_bytes)", "legendFormat": "{{name}}" } ]
    },
    {
      "type": "table", "title": "Restarts & OOM (last 24h)", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [ { "refId": "A", "expr": "docker_container_restarts", "format": "table", "instant": true }, { "refId": "B", "expr": "docker_container_oom_killed", "format": "table", "instant": true } ],
      "transformations": [ { "id": "merge" }, { "id": "organize", "options": { "renameByName": { "name": "Container", "Value #A": "Restarts", "Value #B": "OOM killed" }, "excludeByName": { "Time": true, "__name__": true, "id": true, "instance": true, "job": true, "image": true } } } ]
    },
    {
      "type": "timeseries", "title": "Network per container", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [ { "refId": "A", "expr": "topk(10, rate(docker_container_network_rx_bytes[5m]))", "legendFormat": "{{name}} rx" } ]
    },
    { "type": "row", "title": "Synthetic probes", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 } },
    {
      "type": "timeseries", "title": "Probe latency", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 12, "x": 0, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [ { "refId": "A", "expr": "sum by (instance) (probe_http_duration_seconds)", "legendFormat": "{{instance}}" } ]
    },
    {
      "type": "timeseries", "title": "TLS cert days remaining", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 12, "x": 12, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "d", "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 14 }, { "color": "green", "value": 30 } ] } } },
      "targets": [ { "refId": "A", "expr": "(probe_ssl_earliest_cert_expiry - time())/86400", "legendFormat": "{{instance}}" } ]
    }
  ]
}
