{
  "uid": "oculory-legion",
  "title": "Oculory — Legion",
  "tags": ["oculory", "legion"],
  "timezone": "Asia/Bangkok",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-12h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    { "type": "row", "title": "Signal pipeline", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "type": "timeseries", "title": "Cycles per hour (started / completed / failed)", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "targets": [ { "refId": "A", "expr": "sum by (status) (increase(legion_cycles_total[1h]))", "legendFormat": "{{status}}" } ]
    },
    {
      "type": "stat", "title": "Cycle success ratio (24h)", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.8 }, { "color": "green", "value": 0.95 } ] } } },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(increase(legion_cycles_total{status=\"completed\"}[24h])) / clamp_min(sum(increase(legion_cycles_total[24h])),1)" } ]
    },
    {
      "type": "timeseries", "title": "Cycle duration p95", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [ { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(legion_cycle_duration_seconds_bucket[30m])))", "legendFormat": "p95" } ]
    },
    {
      "type": "timeseries", "title": "Signals & votes per hour", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "targets": [ { "refId": "A", "expr": "sum(increase(legion_signals_total[1h]))", "legendFormat": "signals" }, { "refId": "B", "expr": "sum by (agent) (increase(legion_votes_total[1h]))", "legendFormat": "{{agent}} votes" } ]
    },
    { "type": "row", "title": "Agents & Ollama (LLM)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 } },
    {
      "type": "timeseries", "title": "Agent inference latency p50/p95/p99", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.5, sum by (le) (rate(legion_agent_inference_seconds_bucket[10m])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(legion_agent_inference_seconds_bucket[10m])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(legion_agent_inference_seconds_bucket[10m])))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "timeseries", "title": "Ollama request latency p50/p95", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 8, "w": 6, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [ { "refId": "A", "expr": "histogram_quantile(0.5, sum by (le) (rate(legion_ollama_request_seconds_bucket[10m])))", "legendFormat": "p50" }, { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(legion_ollama_request_seconds_bucket[10m])))", "legendFormat": "p95" } ]
    },
    {
      "type": "timeseries", "title": "Ollama container memory (vs 12g cap)", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 8, "w": 6, "x": 18, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [ { "refId": "A", "expr": "docker_container_memory_usage_bytes{name=\"legion-ollama\"}", "legendFormat": "working set" }, { "refId": "B", "expr": "docker_container_memory_limit_bytes{name=\"legion-ollama\"}", "legendFormat": "limit" } ]
    },
    { "type": "row", "title": "NATS JetStream", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 } },
    {
      "type": "timeseries", "title": "Messages in/out (msg/s)", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [ { "refId": "A", "expr": "rate(gnatsd_varz_in_msgs[5m])", "legendFormat": "in" }, { "refId": "B", "expr": "rate(gnatsd_varz_out_msgs[5m])", "legendFormat": "out" } ]
    },
    {
      "type": "timeseries", "title": "JetStream messages / consumers / streams", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 8, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "targets": [
        { "refId": "A", "expr": "jetstream_server_total_messages", "legendFormat": "messages" },
        { "refId": "B", "expr": "jetstream_server_total_consumers", "legendFormat": "consumers" },
        { "refId": "C", "expr": "jetstream_server_total_streams", "legendFormat": "streams" },
        { "refId": "D", "expr": "gnatsd_varz_slow_consumers", "legendFormat": "slow consumers" }
      ]
    },
    {
      "type": "timeseries", "title": "NATS server mem / connections", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 16, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [ { "refId": "A", "expr": "gnatsd_varz_mem", "legendFormat": "mem" }, { "refId": "B", "expr": "gnatsd_varz_connections", "legendFormat": "conns" } ]
    },
    { "type": "row", "title": "API (read) & containers", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 } },
    {
      "type": "timeseries", "title": "API RED (rate / 5xx / p99)", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 12, "x": 0, "y": 26 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_request_duration_seconds_count{service=\"legion\"}[5m]))", "legendFormat": "req/s" },
        { "refId": "B", "expr": "sum(rate(http_request_duration_seconds_count{service=\"legion\",status_code=~\"5..\"}[5m]))", "legendFormat": "5xx/s" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"legion\"}[5m])))", "legendFormat": "p99 (s)" }
      ]
    },
    {
      "type": "timeseries", "title": "Per-container CPU", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 12, "x": 12, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "targets": [ { "refId": "A", "expr": "docker_container_cpu_percent{name=~\"legion-.*\"}", "legendFormat": "{{name}}" } ]
    },
    { "type": "row", "title": "Distributed cycle traces", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 } },
    {
      "type": "table", "title": "Recent legion traces (click to open)", "datasource": { "uid": "tempo" }, "gridPos": { "h": 9, "w": 24, "x": 0, "y": 34 },
      "targets": [ { "refId": "A", "queryType": "traceqlSearch", "filters": [ { "id": "svc", "tag": "service.name", "operator": "=", "scope": "resource", "value": ["legion"] } ], "limit": 20 } ]
    },
    {
      "type": "logs", "title": "Recent logs (all legion roles)", "datasource": { "uid": "loki" }, "gridPos": { "h": 9, "w": 24, "x": 0, "y": 43 },
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true },
      "targets": [ { "refId": "A", "expr": "{service=\"legion\"} | json", "queryType": "range" } ]
    }
  ]
}
