{
  "uid": "oculory-slo",
  "title": "Oculory — SLO / Error Budget",
  "tags": ["oculory", "slo"],
  "timezone": "Asia/Bangkok",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": { "from": "now-30d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service", "type": "custom", "label": "Service",
        "multi": true, "includeAll": true, "allValue": ".+",
        "query": "gunvest,legion,horizon",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "gunvest", "value": "gunvest" },
          { "text": "legion", "value": "legion" },
          { "text": "horizon", "value": "horizon" }
        ]
      },
      {
        "name": "slo", "type": "custom", "label": "Availability SLO",
        "query": "0.99,0.995,0.999,0.9995",
        "current": { "text": "0.999", "value": "0.999" },
        "options": [
          { "text": "0.99", "value": "0.99" },
          { "text": "0.995", "value": "0.995" },
          { "text": "0.999", "value": "0.999", "selected": true },
          { "text": "0.9995", "value": "0.9995" }
        ]
      },
      {
        "name": "lat", "type": "custom", "label": "Latency target (s)",
        "query": "0.25,0.5,1,2",
        "current": { "text": "0.5", "value": "0.5" },
        "options": [
          { "text": "0.25", "value": "0.25" },
          { "text": "0.5", "value": "0.5", "selected": true },
          { "text": "1", "value": "1" },
          { "text": "2", "value": "2" }
        ]
      }
    ]
  },
  "panels": [
    { "type": "text", "title": "", "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": { "mode": "markdown", "content": "## Service SLOs\nAvailability SLO = **$slo** · Latency target = **${lat}s** · window follows the dashboard time range (default 30d).\nError budget = allowed failure ratio `1 - SLO`. **Burn rate > 1** = spending budget faster than sustainable; multi-window thresholds (Google SRE): **14.4** (1h fast burn → page) and **6** (6h slow burn → ticket)." } },

    { "type": "row", "title": "Availability & budget", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 3 } },
    {
      "type": "stat", "title": "Availability (range) by service",
      "datasource": { "uid": "prometheus" }, "gridPos": { "h": 6, "w": 8, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0.95, "max": 1, "decimals": 4,
        "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.99 }, { "color": "green", "value": 0.999 } ] } } },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal" },
      "targets": [ { "refId": "A",
        "expr": "sum by (service) (rate(http_request_duration_seconds_count{service=~\"$service\",status_code!~\"5..\"}[$__range])) / clamp_min(sum by (service) (rate(http_request_duration_seconds_count{service=~\"$service\"}[$__range])), 0.0001)",
        "legendFormat": "{{service}}" } ]
    },
    {
      "type": "gauge", "title": "Error budget remaining by service",
      "datasource": { "uid": "prometheus" }, "gridPos": { "h": 6, "w": 8, "x": 8, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1,
        "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.25 }, { "color": "green", "value": 0.5 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto" },
      "targets": [ { "refId": "A",
        "expr": "clamp_max(clamp_min( ( (sum by (service) (rate(http_request_duration_seconds_count{service=~\"$service\",status_code!~\"5..\"}[$__range])) / clamp_min(sum by (service)(rate(http_request_duration_seconds_count{service=~\"$service\"}[$__range])),0.0001)) - $slo ) / (1 - $slo), 0), 1)",
        "legendFormat": "{{service}}" } ]
    },
    {
      "type": "stat", "title": "Latency SLI — % faster than ${lat}s",
      "datasource": { "uid": "prometheus" }, "gridPos": { "h": 6, "w": 8, "x": 16, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0.9, "max": 1, "decimals": 4,
        "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 } ] } } },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal" },
      "targets": [ { "refId": "A",
        "expr": "sum by (service) (rate(http_request_duration_seconds_bucket{service=~\"$service\",le=\"$lat\"}[$__range])) / clamp_min(sum by (service)(rate(http_request_duration_seconds_count{service=~\"$service\"}[$__range])),0.0001)",
        "legendFormat": "{{service}}" } ]
    },

    { "type": "row", "title": "Multi-window burn rate", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 } },
    {
      "type": "timeseries", "title": "Fast burn (1h error-budget burn rate)",
      "datasource": { "uid": "prometheus" }, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "thresholdsStyle": { "mode": "line" } },
        "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 14.4 } ] } } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A",
        "expr": "(sum by (service) (rate(http_request_duration_seconds_count{service=~\"$service\",status_code=~\"5..\"}[1h])) / clamp_min(sum by (service)(rate(http_request_duration_seconds_count{service=~\"$service\"}[1h])),0.0001)) / (1 - $slo)",
        "legendFormat": "{{service}} 1h" } ]
    },
    {
      "type": "timeseries", "title": "Slow burn (6h error-budget burn rate)",
      "datasource": { "uid": "prometheus" }, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "thresholdsStyle": { "mode": "line" } },
        "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 6 } ] } } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A",
        "expr": "(sum by (service) (rate(http_request_duration_seconds_count{service=~\"$service\",status_code=~\"5..\"}[6h])) / clamp_min(sum by (service)(rate(http_request_duration_seconds_count{service=~\"$service\"}[6h])),0.0001)) / (1 - $slo)",
        "legendFormat": "{{service}} 6h" } ]
    },

    { "type": "row", "title": "SLIs over time", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 } },
    {
      "type": "timeseries", "title": "Request rate vs error rate",
      "datasource": { "uid": "prometheus" }, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "refId": "A", "expr": "sum by (service) (rate(http_request_duration_seconds_count{service=~\"$service\"}[5m]))", "legendFormat": "{{service}} total" },
        { "refId": "B", "expr": "sum by (service) (rate(http_request_duration_seconds_count{service=~\"$service\",status_code=~\"5..\"}[5m]))", "legendFormat": "{{service}} 5xx" }
      ]
    },
    {
      "type": "timeseries", "title": "Rolling availability (1h)",
      "datasource": { "uid": "prometheus" }, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0.95, "max": 1, "decimals": 4,
        "custom": { "thresholdsStyle": { "mode": "line" } },
        "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 0.999 } ] } } },
      "targets": [ { "refId": "A",
        "expr": "sum by (service) (rate(http_request_duration_seconds_count{service=~\"$service\",status_code!~\"5..\"}[1h])) / clamp_min(sum by (service)(rate(http_request_duration_seconds_count{service=~\"$service\"}[1h])),0.0001)",
        "legendFormat": "{{service}}" } ]
    }
  ]
}
