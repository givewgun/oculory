{
  "uid": "oculory-gunvest",
  "title": "Oculory — GunVest",
  "tags": ["oculory", "gunvest"],
  "timezone": "Asia/Bangkok",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    { "type": "row", "title": "RED — HTTP", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "type": "timeseries", "title": "Request rate by route",
      "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [ { "refId": "A", "expr": "sum by (route) (rate(http_request_duration_seconds_count{service=\"gunvest\"}[5m]))", "legendFormat": "{{route}}" } ]
    },
    {
      "type": "timeseries", "title": "Errors (4xx / 5xx)",
      "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_request_duration_seconds_count{service=\"gunvest\",status_code=~\"4..\"}[5m]))", "legendFormat": "4xx" },
        { "refId": "B", "expr": "sum(rate(http_request_duration_seconds_count{service=\"gunvest\",status_code=~\"5..\"}[5m]))", "legendFormat": "5xx" }
      ]
    },
    {
      "type": "timeseries", "title": "Latency p50/p95/p99",
      "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.5, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"gunvest\"}[5m])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"gunvest\"}[5m])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"gunvest\"}[5m])))", "legendFormat": "p99" }
      ]
    },
    { "type": "row", "title": "Database (Postgres)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 } },
    {
      "type": "timeseries", "title": "Connections", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 0, "y": 9 },
      "targets": [ { "refId": "A", "expr": "sum(pg_stat_activity_count)", "legendFormat": "active" }, { "refId": "B", "expr": "max(pg_settings_max_connections)", "legendFormat": "max" } ]
    },
    {
      "type": "timeseries", "title": "Cache hit ratio", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 8, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } },
      "targets": [ { "refId": "A", "expr": "sum(rate(pg_stat_database_blks_hit[5m])) / clamp_min(sum(rate(pg_stat_database_blks_hit[5m]))+sum(rate(pg_stat_database_blks_read[5m])),1)", "legendFormat": "hit ratio" } ]
    },
    {
      "type": "timeseries", "title": "Commits vs rollbacks / deadlocks", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 16, "y": 9 },
      "targets": [ { "refId": "A", "expr": "sum(rate(pg_stat_database_xact_commit[5m]))", "legendFormat": "commit/s" }, { "refId": "B", "expr": "sum(rate(pg_stat_database_xact_rollback[5m]))", "legendFormat": "rollback/s" }, { "refId": "C", "expr": "sum(rate(pg_stat_database_deadlocks[5m]))", "legendFormat": "deadlocks/s" } ]
    },
    { "type": "row", "title": "Runtime & jobs", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 } },
    {
      "type": "timeseries", "title": "Event-loop lag p99 / heap", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 0, "y": 17 },
      "targets": [ { "refId": "A", "expr": "nodejs_eventloop_lag_p99_seconds{service=\"gunvest\"}", "legendFormat": "loop lag p99 (s)" }, { "refId": "B", "expr": "nodejs_heap_size_used_bytes{service=\"gunvest\"}", "legendFormat": "heap used" } ]
    },
    {
      "type": "timeseries", "title": "Background jobs (runs/s)", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 8, "y": 17 },
      "targets": [ { "refId": "A", "expr": "sum by (job_name) (rate(gunvest_job_runs_total[5m]))", "legendFormat": "{{job_name}}" } ]
    },
    {
      "type": "table", "title": "Job freshness (age since last success)", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 16, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [ { "refId": "A", "expr": "time() - gunvest_job_last_success_timestamp_seconds", "format": "table", "instant": true } ],
      "transformations": [ { "id": "organize", "options": { "renameByName": { "job_name": "Job", "Value": "Age (s)" }, "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true, "service": true } } } ]
    },
    {
      "type": "timeseries", "title": "Outbound dependency latency p95", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [ { "refId": "A", "expr": "histogram_quantile(0.95, sum by (upstream,le) (rate(gunvest_upstream_request_duration_seconds_bucket[5m])))", "legendFormat": "{{upstream}}" } ]
    },
    {
      "type": "timeseries", "title": "Outbound dependency errors/s", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 7, "w": 12, "x": 12, "y": 24 },
      "targets": [ { "refId": "A", "expr": "sum by (upstream) (rate(gunvest_upstream_requests_total{outcome=\"error\"}[5m]))", "legendFormat": "{{upstream}}" } ]
    },
    { "type": "row", "title": "Logs & traces", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 } },
    {
      "type": "logs", "title": "Recent logs", "datasource": { "uid": "loki" }, "gridPos": { "h": 9, "w": 24, "x": 0, "y": 32 },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "enableLogDetails": true },
      "targets": [ { "refId": "A", "expr": "{service=\"gunvest\"} | json", "queryType": "range" } ]
    },
    { "type": "row", "title": "Business (Access-gated)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 }, "collapsed": true,
      "panels": [
        { "type": "stat", "title": "Portfolio value", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 6, "w": 6, "x": 0, "y": 42 }, "fieldConfig": { "defaults": { "unit": "currencyUSD" } }, "targets": [ { "refId": "A", "expr": "gunvest_portfolio_value_usd" } ] },
        { "type": "stat", "title": "Unrealized P&L", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 6, "w": 6, "x": 6, "y": 42 }, "fieldConfig": { "defaults": { "unit": "currencyUSD" } }, "targets": [ { "refId": "A", "expr": "gunvest_pnl_unrealized_usd" } ] },
        { "type": "gauge", "title": "Distance to $1M", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 6, "w": 6, "x": 12, "y": 42 }, "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } }, "targets": [ { "refId": "A", "expr": "gunvest_portfolio_value_usd / 1000000" } ] },
        { "type": "stat", "title": "Risk environment", "datasource": { "uid": "prometheus" }, "gridPos": { "h": 6, "w": 6, "x": 18, "y": 42 }, "targets": [ { "refId": "A", "expr": "gunvest_risk_environment_level" } ] }
      ]
    }
  ]
}
