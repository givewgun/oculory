# Oculory configuration. Copy to .env and fill in. NEVER commit the real .env.
#   cp .env.example .env

# ---- Grafana ----
GRAFANA_ADMIN_PW=change-me-strong

# ---- Shared docker networks (override only if the gunvest/legion projects were
#      deployed under different compose project names). Discover with:
#         docker network ls
#      gunvest stack -> docker_default ; legion internal -> app_legion
GUNVEST_NETWORK=docker_default
LEGION_NETWORK=app_legion

# ---- postgres-exporter DSN -> gunvest-db ----
# Prefer a dedicated read-only monitoring role (see scripts/create-pg-monitor.sql).
# Reachable as host `gunvest-db` over the gunvest network.
#   postgresql://USER:PASSWORD@gunvest-db:5432/DBNAME?sslmode=disable
PG_EXPORTER_DSN=postgresql://oculory_ro:CHANGE_ME@gunvest-db:5432/gunvest?sslmode=disable

# ---- Alertmanager: Telegram (create a NEW bot via @BotFather) ----
TELEGRAM_BOT_TOKEN=123456:CHANGE_ME
TELEGRAM_CHAT_ID=000000000

# ---- Alertmanager: Email (SMTP) ----
SMTP_SMARTHOST=smtp.gmail.com:587
SMTP_FROM=oculory-alerts@givewgun.com
SMTP_USER=aongoong.jp@gmail.com
SMTP_PASSWORD=app-password-here
ALERT_EMAIL_TO=aongoong.jp@gmail.com
